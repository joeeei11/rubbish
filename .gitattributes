# 统一行尾：仓库内存 LF，Windows checkout 自动转 CRLF
* text=auto

# 明确指定文本文件
*.py    text eol=lf
*.js    text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.txt   text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.conf  text eol=lf
*.wxml  text eol=lf
*.wxss  text eol=lf
*.sh    text eol=lf

# 二进制文件不转换
*.pth   binary
*.png   binary
*.jpg   binary
*.jpeg  binary
