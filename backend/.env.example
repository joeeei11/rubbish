# ========== Flask ==========
FLASK_ENV=development
SECRET_KEY=your-secret-key-here-change-in-production

# ========== 数据库 ==========
DATABASE_URL=mysql+pymysql://root:password@localhost:3306/garbage_db
REDIS_URL=redis://localhost:6379/0

# ========== 微信小程序 ==========
WECHAT_APP_ID=your-wechat-appid
WECHAT_APP_SECRET=your-wechat-secret

# ========== 百度 ASR 语音识别 ==========
BAIDU_ASR_APP_ID=your-baidu-app-id
BAIDU_ASR_API_KEY=your-baidu-api-key
BAIDU_ASR_SECRET_KEY=your-baidu-secret-key

# ========== 腾讯云 COS（开发期留空，使用本地存储）==========
COS_SECRET_ID=
COS_SECRET_KEY=
COS_BUCKET=
COS_REGION=ap-guangzhou

# ========== AI 模型 ==========
MODEL_WEIGHTS_PATH=ai_model/weights/mobilenetv3_garbage.pth
MODEL_INPUT_SIZE=224
MODEL_CONFIDENCE_THRESHOLD=0.6

# ========== 本地图片存储（开发期）==========
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH=10485760
