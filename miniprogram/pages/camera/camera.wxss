.container {
  min-height: 100vh;
  padding: 28rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #eff6ff 0%, #f8fafc 45%, #ffffff 100%);
}

.hero-card,
.preview-card,
.status-card,
.tips-card {
  background: #ffffff;
  border-radius: 28rpx;
  box-shadow: 0 14rpx 36rpx rgba(15, 23, 42, 0.08);
}

.hero-card,
.preview-card,
.status-card,
.tips-card {
  padding: 28rpx;
}

.hero-title,
.tips-title,
.status-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #0f172a;
}

.hero-desc,
.status-desc,
.preview-tip,
.tips-item {
  display: block;
  margin-top: 12rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #475569;
}

.preview-card,
.status-card,
.tips-card,
.action-group {
  margin-top: 24rpx;
}

.preview-image {
  width: 100%;
  height: 420rpx;
  border-radius: 20rpx;
  background: #e2e8f0;
}

.action-group {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.primary-button,
.secondary-button {
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 700;
}

.primary-button {
  background: linear-gradient(135deg, #0284c7 0%, #0ea5e9 100%);
  color: #ffffff;
}

.secondary-button {
  background: #ffffff;
  color: #0f172a;
  border: 2rpx solid #cbd5e1;
}

.error {
  border: 2rpx solid #fecaca;
  background: #fff7f7;
}

.hidden-canvas {
  position: fixed;
  left: -9999px;
  top: -9999px;
  opacity: 0;
  pointer-events: none;
}
