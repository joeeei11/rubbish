.container {
  min-height: 100vh;
  padding: 28rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #FFF7ED 0%, #F8FAFC 42%, #FFFFFF 100%);
}

.hero-card,
.status-card,
.history-item,
.empty-state {
  background: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 12rpx 32rpx rgba(15, 23, 42, 0.08);
}

.hero-card,
.status-card,
.empty-state {
  padding: 28rpx;
}

.hero-card {
  margin-bottom: 24rpx;
}

.hero-title {
  display: block;
  font-size: 38rpx;
  font-weight: 700;
  color: #9A3412;
}

.hero-desc {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #6B7280;
}

.status-card,
.empty-state {
  margin-top: 24rpx;
  color: #6B7280;
  text-align: center;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-top: 24rpx;
}

.history-item {
  padding: 24rpx;
}

.history-head,
.history-foot {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
}

.type-badge {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: #FFF7ED;
}

.type-icon {
  font-size: 28rpx;
}

.type-text,
.time-text,
.query-input {
  font-size: 22rpx;
  color: #64748B;
}

.history-name {
  display: block;
  margin-top: 16rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #111827;
}

.history-desc {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #6B7280;
}

.history-foot {
  margin-top: 18rpx;
}

.query-input {
  flex: 1;
  text-align: right;
}

.empty-action {
  display: inline-block;
  margin-top: 20rpx;
  padding: 16rpx 28rpx;
  border-radius: 999rpx;
  background: #F97316;
  color: #FFFFFF;
  font-size: 24rpx;
}
