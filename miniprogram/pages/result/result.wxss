.container {
  min-height: 100vh;
  padding: 28rpx;
  background: linear-gradient(180deg, #ecfeff 0%, #f8fafc 50%, #ffffff 100%);
  box-sizing: border-box;
}

.hero-card,
.info-card,
.status-card,
.warning-card {
  background: #ffffff;
  border-radius: 28rpx;
  box-shadow: 0 14rpx 36rpx rgba(15, 23, 42, 0.08);
}

.hero-card {
  padding: 30rpx;
}

.hero-image {
  width: 100%;
  height: 360rpx;
  border-radius: 24rpx;
  background: #e2e8f0;
  margin-bottom: 22rpx;
}

.hero-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
}

.confidence-text {
  font-size: 24rpx;
  color: #0f766e;
  font-weight: 600;
}

.item-name {
  display: block;
  margin-top: 18rpx;
  font-size: 42rpx;
  font-weight: 700;
  color: #111827;
}

.item-desc {
  display: block;
  margin-top: 14rpx;
  font-size: 26rpx;
  color: #4b5563;
  line-height: 1.7;
}

.info-card,
.status-card,
.warning-card {
  margin-top: 24rpx;
  padding: 28rpx;
}

.warning-card {
  border: 2rpx solid #fed7aa;
  background: #fff7ed;
}

.section-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #14532d;
}

.section-content {
  display: block;
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #374151;
  line-height: 1.7;
}

.action-row {
  display: flex;
  gap: 18rpx;
  margin-top: 24rpx;
}

.primary-action,
.secondary-action,
.ghost-action {
  margin-top: 24rpx;
  padding: 28rpx;
  border-radius: 24rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 700;
}

.primary-action {
  background: linear-gradient(135deg, #16a34a 0%, #22c55e 100%);
  color: #ffffff;
}

.secondary-action,
.ghost-action {
  flex: 1;
  padding: 22rpx 18rpx;
  border-radius: 22rpx;
  text-align: center;
}

.secondary-action {
  background: #0f766e;
  color: #ffffff;
}

.ghost-action {
  background: #ffffff;
  border: 2rpx solid #fdba74;
  color: #9a3412;
}

.related-list,
.top-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 16rpx;
}

.related-item,
.top-item {
  padding: 22rpx 20rpx;
  border-radius: 20rpx;
  background: #f8fafc;
  border: 2rpx solid #e5e7eb;
}

.top-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.top-name,
.related-name {
  display: block;
  font-size: 28rpx;
  color: #111827;
  font-weight: 600;
}

.top-score,
.related-tag {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #6b7280;
}
