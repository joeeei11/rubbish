<view class="container">
  <view class="hero-card">
    <text class="hero-title">语音查询</text>
    <text class="hero-desc">点击输入框后，按键盘上的🎤按钮说话，识别文字后点搜索即可。</text>
  </view>

  <view class="search-bar">
    <input
      class="search-input"
      placeholder="说出或输入垃圾名称"
      value="{{keyword}}"
      focus="{{inputFocus}}"
      confirm-type="search"
      bindinput="onInputChange"
      bindconfirm="onInputConfirm"
    />
    <view class="clear-btn" wx:if="{{keyword}}" bindtap="clearInput">
      <text>✕</text>
    </view>
    <view
      class="search-btn {{searching ? 'search-btn--disabled' : ''}}"
      bindtap="handleSearch"
    >
      <text>{{searching ? '搜索中' : '搜索'}}</text>
    </view>
  </view>

  <view class="status-card" wx:if="{{errorMessage}}">
    <text class="status-text status-text--error">{{errorMessage}}</text>
  </view>

  <view class="result-list" wx:if="{{results.length}}">
    <view class="section-head">
      <text class="section-title">查询结果</text>
    </view>

    <view
      class="result-item"
      wx:for="{{results}}"
      wx:key="id"
      bindtap="goDetail"
      data-id="{{item.id}}"
    >
      <view class="result-main">
        <text class="result-name">{{item.name}}</text>
        <text class="result-desc">{{item.reason || item.description}}</text>
      </view>
      <category-badge
        text="{{item.category.name}}"
        code="{{item.category.code}}"
        color="{{item.category.color}}"
      />
    </view>
  </view>

  <view class="empty-state" wx:elif="{{!searching}}">
    <text>{{emptyText}}</text>
  </view>

  <view class="tips-card">
    <text class="tips-title">使用提示</text>
    <text class="tips-item">1. 点击输入框弹出键盘</text>
    <text class="tips-item">2. 点击键盘左下角的🎤按钮切换到语音输入</text>
    <text class="tips-item">3. 说出物品名称，如"矿泉水瓶""干电池"</text>
    <text class="tips-item">4. 识别完成后点击"搜索"按钮</text>
  </view>
</view>
