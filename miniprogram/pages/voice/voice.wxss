.container {
  min-height: 100vh;
  padding: 28rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #ECFEFF 0%, #F8FAFC 40%, #FFFFFF 100%);
}

.hero-card,
.record-panel,
.permission-card,
.result-card,
.status-card,
.result-item,
.empty-state {
  background: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 12rpx 32rpx rgba(15, 23, 42, 0.08);
}

.hero-card,
.record-panel,
.permission-card,
.result-card,
.status-card,
.empty-state {
  padding: 28rpx;
}

.hero-card {
  margin-bottom: 24rpx;
}

.hero-title {
  display: block;
  font-size: 38rpx;
  font-weight: 700;
  color: #155E75;
}

.hero-desc {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #4B5563;
}

.record-panel {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.wave-group {
  display: flex;
  align-items: flex-end;
  justify-content: center;
  gap: 12rpx;
  height: 110rpx;
  margin-bottom: 20rpx;
}

.wave-bar {
  width: 14rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #CFFAFE 0%, #06B6D4 100%);
  transition: height 0.18s ease;
}

.wave-bar--active {
  box-shadow: 0 0 18rpx rgba(8, 145, 178, 0.35);
}

.panel-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #0F172A;
}

.panel-desc {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #64748B;
}

.record-button {
  margin-top: 28rpx;
  min-width: 320rpx;
  padding: 24rpx 36rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #06B6D4 0%, #0891B2 100%);
  box-shadow: 0 16rpx 34rpx rgba(8, 145, 178, 0.22);
}

.record-button--active {
  background: linear-gradient(135deg, #F97316 0%, #EA580C 100%);
  box-shadow: 0 16rpx 34rpx rgba(234, 88, 12, 0.25);
}

.record-button--disabled {
  opacity: 0.7;
}

.record-button-text {
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 700;
}

.permission-card,
.result-card,
.status-card,
.empty-state,
.result-list {
  margin-top: 24rpx;
}

.permission-title,
.result-title,
.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #0F172A;
}

.permission-desc {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #64748B;
}

.permission-actions,
.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 20rpx;
}

.primary-action,
.secondary-action,
.text-link,
.empty-action {
  padding: 16rpx 24rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  text-align: center;
}

.primary-action {
  background: #06B6D4;
  color: #FFFFFF;
}

.secondary-action,
.empty-action {
  background: #ECFEFF;
  color: #0F766E;
}

.text-link {
  padding: 0;
  background: transparent;
  color: #0891B2;
}

.recognized-text {
  display: block;
  margin-top: 14rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: #0F766E;
}

.recognized-text--empty {
  color: #94A3B8;
  font-weight: 500;
}

.status-text {
  font-size: 26rpx;
  color: #0F766E;
}

.status-text--error {
  color: #DC2626;
}

.result-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.result-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx;
}

.result-main {
  flex: 1;
}

.result-name {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #111827;
}

.result-desc {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: #6B7280;
}

.empty-state {
  text-align: center;
  color: #64748B;
}
