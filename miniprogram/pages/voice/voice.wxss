.container {
  min-height: 100vh;
  padding: 28rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #ECFEFF 0%, #F8FAFC 40%, #FFFFFF 100%);
}

.hero-card,
.status-card,
.result-item,
.empty-state,
.tips-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 12rpx 32rpx rgba(15, 23, 42, 0.08);
}

.hero-card,
.status-card,
.empty-state,
.tips-card {
  padding: 28rpx;
}

.hero-card {
  margin-bottom: 24rpx;
}

.hero-title {
  display: block;
  font-size: 38rpx;
  font-weight: 700;
  color: #155E75;
}

.hero-desc {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #4B5563;
}

/* 搜索栏 */
.search-bar {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 12rpx 16rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 12rpx 32rpx rgba(15, 23, 42, 0.08);
}

.search-input {
  flex: 1;
  height: 72rpx;
  font-size: 30rpx;
  padding: 0 16rpx;
  color: #1F2937;
}

.clear-btn {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12rpx;
}

.clear-btn text {
  font-size: 28rpx;
  color: #9CA3AF;
}

.search-btn {
  background: linear-gradient(135deg, #06B6D4 0%, #0891B2 100%);
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 600;
  padding: 16rpx 36rpx;
  border-radius: 999rpx;
  white-space: nowrap;
  box-shadow: 0 8rpx 20rpx rgba(8, 145, 178, 0.22);
}

.search-btn--disabled {
  opacity: 0.6;
}

/* 状态 */
.status-card {
  margin-bottom: 24rpx;
}

.status-text--error {
  color: #DC2626;
  font-size: 26rpx;
}

/* 结果 */
.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #0F172A;
}

.result-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-bottom: 24rpx;
}

.result-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx;
}

.result-main {
  flex: 1;
}

.result-name {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #111827;
}

.result-desc {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: #6B7280;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.empty-state {
  text-align: center;
  color: #64748B;
  padding: 80rpx 40rpx;
}

/* 提示卡片 */
.tips-card {
  margin-top: 12rpx;
}

.tips-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #155E75;
  margin-bottom: 16rpx;
}

.tips-item {
  display: block;
  font-size: 26rpx;
  color: #6B7280;
  line-height: 2;
}
