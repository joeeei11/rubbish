.container {
  min-height: 100vh;
  padding: 28rpx;
  background: linear-gradient(180deg, #EFF6FF 0%, #F8FAFC 45%, #FFFFFF 100%);
  box-sizing: border-box;
}

.hero-card,
.status-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 12rpx 32rpx rgba(15, 23, 42, 0.08);
}

.hero-card {
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.hero-title {
  display: block;
  font-size: 38rpx;
  font-weight: 700;
  color: #1D4ED8;
}

.hero-desc {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #4B5563;
  line-height: 1.7;
}

.status-card {
  padding: 28rpx;
  text-align: center;
  color: #6B7280;
}
