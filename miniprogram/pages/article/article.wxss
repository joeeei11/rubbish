.container {
  min-height: 100vh;
  padding: 28rpx;
  background: linear-gradient(180deg, #FFF7ED 0%, #F8FAFC 45%, #FFFFFF 100%);
  box-sizing: border-box;
}

.hero-card,
.article-card,
.detail-card,
.status-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 12rpx 32rpx rgba(15, 23, 42, 0.08);
}

.hero-card {
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.hero-title {
  display: block;
  font-size: 38rpx;
  font-weight: 700;
  color: #C2410C;
}

.hero-desc {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #4B5563;
  line-height: 1.7;
}

.list-wrap {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.article-card,
.detail-card,
.status-card {
  padding: 28rpx;
}

.card-title,
.article-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #111827;
}

.card-summary,
.article-content {
  display: block;
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #374151;
  line-height: 1.8;
  white-space: pre-wrap;
}

.card-meta,
.article-meta {
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #6B7280;
}

.back-btn {
  display: inline-block;
  margin-bottom: 20rpx;
  padding: 8rpx 0;
  font-size: 26rpx;
  color: #4CAF50;
}
