.container {
  min-height: 100vh;
  padding: 28rpx;
  background: linear-gradient(180deg, #F0FDF4 0%, #F8FAFC 45%, #FFFFFF 100%);
  box-sizing: border-box;
}

.hero-card,
.search-box,
.result-item,
.empty-state,
.status-text {
  background: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 12rpx 32rpx rgba(15, 23, 42, 0.08);
}

.hero-card {
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.hero-title {
  display: block;
  font-size: 38rpx;
  font-weight: 700;
  color: #14532D;
}

.hero-desc {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #4B5563;
  line-height: 1.6;
}

.search-box {
  padding: 22rpx 24rpx;
}

.search-input {
  width: 100%;
  font-size: 30rpx;
  color: #111827;
}

.status-text,
.empty-state {
  margin-top: 24rpx;
  padding: 28rpx;
  text-align: center;
  color: #6B7280;
}

.result-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-top: 24rpx;
}

.result-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx;
}

.result-main {
  flex: 1;
}

.result-name {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #111827;
}

.result-desc {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #6B7280;
  line-height: 1.5;
}
