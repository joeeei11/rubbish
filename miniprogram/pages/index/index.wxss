/* pages/index/index.wxss */
.container {
  padding: 40rpx;
}
.header {
  text-align: center;
  margin-bottom: 60rpx;
}
.title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #4CAF50;
}
.subtitle {
  display: block;
  font-size: 26rpx;
  color: #999;
  margin-top: 12rpx;
}
.actions {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
}
.action-item {
  flex: 1 1 40%;
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx 20rpx;
  text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,.06);
}
.action-icon {
  display: block;
  font-size: 64rpx;
}
.action-label {
  display: block;
  margin-top: 16rpx;
  font-size: 28rpx;
  color: #333;
}
