<view class="container">
  <view class="hero-card">
    <text class="hero-greeting">你好，{{greetingName}}</text>
    <text class="hero-title">智能垃圾分类助手</text>
    <text class="hero-desc">拍照、语音、文字三种方式都能快速找到正确分类，还能顺手了解背后的分类逻辑。</text>
  </view>

  <view class="section-head">
    <text class="section-title">常用功能</text>
  </view>

  <view class="actions-grid">
    <view class="action-item action-item--camera" bindtap="goCamera">
      <text class="action-icon">📷</text>
      <text class="action-label">拍照识别</text>
      <text class="action-desc">拍一下，马上看结果</text>
    </view>
    <view class="action-item action-item--voice" bindtap="goVoice">
      <text class="action-icon">🎤</text>
      <text class="action-label">语音查询</text>
      <text class="action-desc">按住说出垃圾名称</text>
    </view>
    <view class="action-item action-item--search" bindtap="goSearch">
      <text class="action-icon">🔍</text>
      <text class="action-label">文字搜索</text>
      <text class="action-desc">支持别名和模糊搜索</text>
    </view>
    <view class="action-item action-item--history" bindtap="goHistory">
      <text class="action-icon">🕘</text>
      <text class="action-label">查询历史</text>
      <text class="action-desc">回看最近识别记录</text>
    </view>
  </view>

  <view class="section-head">
    <text class="section-title">今日科普</text>
  </view>

  <view class="article-card" bindtap="openTodayArticle">
    <text class="article-tag">推荐阅读</text>
    <text class="article-title">{{todayArticle ? todayArticle.title : '加载中...'}}</text>
    <text class="article-summary">
      {{todayArticle ? todayArticle.summary : '正在准备今日科普内容'}}
    </text>
  </view>

  <view class="section-head">
    <text class="section-title">分类指南</text>
  </view>

  <view class="guide-grid">
    <view
      class="guide-item"
      wx:for="{{categories}}"
      wx:key="code"
      bindtap="openCategoryGuide"
      data-keyword="{{item.keyword}}"
      style="background: linear-gradient(180deg, {{item.color}} 0%, #FFFFFF 100%);"
    >
      <text class="guide-name">{{item.name}}</text>
      <text class="guide-keyword">试试：{{item.keyword}}</text>
    </view>
  </view>
</view>
